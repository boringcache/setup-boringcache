{
  "name": "setup-boringcache",
  "version": "1.0.0",
  "description": "GitHub Action to install the BoringCache CLI with version pinning and checksum verification",
  "main": "dist/setup/index.js",
  "scripts": {
    "build": "tsc && ncc build lib/setup.ts -o dist/setup",
    "package": "ncc build lib/setup.ts -o dist/setup",
    "test": "jest",
    "test:ci": "jest --ci --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boringcache/setup-boringcache.git"
  },
  "keywords": [
    "actions",
    "setup",
    "boringcache",
    "cli"
  ],
  "author": "BoringCache",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.19.10",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.1",
    "typescript": "^5.0.0"
  }
}
